# Comma-separated list of origins allowed to call this API (CORS).
POLIS_ALLOWED_ORIGINS=http://localhost:3000

# --- LLM reasoning (optional) ------------------------------------------------
# By default (everything below left unset), POLIS runs on its built-in
# deterministic mock reasoning engine -- no API key, no network calls, no
# cost. To use a real LLM for council reasoning instead:
#
#   1. Install the matching optional SDK:
#        pip install -r requirements-llm.txt   # all three providers
#        pip install anthropic                 # just Anthropic
#        pip install openai                    # just OpenAI
#        pip install google-generativeai        # just Gemini
#   2. Set that provider's API key below.
#   3. Set POLIS_LLM_PROVIDER to that provider's name.
#
# Setting an API key alone does NOT activate a provider -- POLIS_LLM_PROVIDER
# must also be set explicitly. If POLIS_LLM_PROVIDER names a provider whose
# key is missing, whose SDK isn't installed, or whose API call fails at
# runtime, POLIS logs a warning and falls back to mock reasoning rather than
# crashing.

# Which provider to use: anthropic | openai | gemini. Leave empty (default)
# to use the mock reasoning engine.
POLIS_LLM_PROVIDER=

# Anthropic (Claude) -- requires: pip install anthropic
# ANTHROPIC_API_KEY=
# POLIS_ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI -- requires: pip install openai
# OPENAI_API_KEY=
# POLIS_OPENAI_MODEL=gpt-4o-mini

# Google Gemini -- requires: pip install google-generativeai
# GEMINI_API_KEY=
# POLIS_GEMINI_MODEL=gemini-2.0-flash
